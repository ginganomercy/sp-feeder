# ============================================
# SMART PET FEEDER - ENVIRONMENT CONFIGURATION
# ============================================
# Copy file ini ke .env dan sesuaikan dengan environment Anda

# Flask Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-32-characters
FLASK_ENV=development
FLASK_DEBUG=True

# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=smart_pet_feeder
MYSQL_PORT=3306

# MQTT Broker Configuration
MQTT_BROKER=broker.hivemq.com
MQTT_PORT=1883
# MQTT_USERNAME=  # Uncomment jika broker memerlukan auth
# MQTT_PASSWORD=  # Uncomment jika broker memerlukan auth

# MQTT Advanced Configuration (Optional)
# MQTT_CLIENT_ID=MeowFeed_Server_01  # Leave empty untuk auto-generate unique ID
# MQTT_KEEPALIVE=60  # MQTT keepalive interval in seconds

# Hardware Configuration
DEFAULT_MAX_CAPACITY=600

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

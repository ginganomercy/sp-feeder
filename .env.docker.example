# ============================================
# Smart Pet Feeder — Production Environment
# COPY this file to .env.docker (jangan di-commit!)
# ============================================

# ──────────────────────────────────────────
# Flask Security
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# ──────────────────────────────────────────
SECRET_KEY=GANTI_DENGAN_SECRET_KEY_64_KARAKTER_HEX
FLASK_ENV=production
FLASK_DEBUG=False

# ──────────────────────────────────────────
# MySQL Database
# MYSQL_DATABASE sudah di-hardcode di docker-compose.yml (= smart_pet_feeder)
# ──────────────────────────────────────────
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=petfeeder
MYSQL_PASSWORD=GANTI_DENGAN_PASSWORD_APP_USER
MYSQL_DB=smart_pet_feeder
MYSQL_ROOT_PASSWORD=GANTI_DENGAN_PASSWORD_ROOT

# ──────────────────────────────────────────
# MQTT Broker (in-docker mosquitto, TLS port)
# ──────────────────────────────────────────
MQTT_BROKER=mosquitto
MQTT_PORT=8883
MQTT_KEEPALIVE=60

# ──────────────────────────────────────────
# Server
# ──────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=info
